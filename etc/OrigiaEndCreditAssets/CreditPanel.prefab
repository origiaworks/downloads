  fadeDispTextData:
  - "\u6B7B\u95D8\u306E\u672B\u3001\u9B54\u738B\u30B8\u30E3\u30C9\u30A6\u3092\u8A0E\u3061\u53D6\u3063\u305F\u3002"
  - "\u3053\u308C\u306B\u3088\u308A\u5149\u3068\u95C7\u306E\u9B54\u529B\u306F\u89E3\u653E\u3055\u308C\u3001\n\u4E16\u754C\u306F\u5E73\u548C\u3092\u53D6\u308A\u623B\u3057\u305F\u3002"
  - "\u4EBA\u3005\u306F\u3053\u306E\u6226\u3044\u3092\u9B54\u529B\u89E3\u653E\u6226\u4E89\u3068\u547C\u3073\u3001\n\u5F8C\u4E16\u306B\u307E\u3067\u8A9E\u308A\u7D99\u3044\u3067\u3044\u3063\u305F\u3002"
  - "\u3057\u304B\u3057\u3001\u6642\u306F\u6D41\u308C...\u73FE\u4EE3\u3002"
  - "\u9B54\u529B\u306F\u4E0D\u8981\u3068\u306A\u308A\u3001\u6642\u4EE3\u3068\u5171\u306B\u8870\u9000\u3002\n\u6570\u3005\u306E\u4F1D\u8AAC\u306F\u98A8\u5316\u3057\u3066\u3044\u3063\u305F\u3002"
  - "\u30CA\u30E0\u30CA\u30A4\u30C4\u9054\u306F\u30AB\u30FC\u30C9\u30B2\u30FC\u30E0\u3068\u3044\u3046\u5F62\u3067\n\u73FE\u4EE3\u306B\u305D\u306E\u59FF\u3053\u305D\u6B8B\u3057\u305F\u304C\u3001"
  - "\u305D\u306E\u8ECC\u8DE1\u3092\u77E5\u308B\u3082\u306E\u306F\u3082\u3046\u3044\u306A\u3044...\u3002"
